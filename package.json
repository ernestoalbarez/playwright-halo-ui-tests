{
  "name": "halo-media-playwright-suite",
  "version": "1.1.0",
  "description": "E2E test automation suite for halopowered.com using Playwright + TypeScript",
  "type": "module",
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "test": "npx playwright test",
    "test:headed": "npx playwright test --headed",
    "test:ui": "npx playwright test --ui",
    "test:chromium": "npx playwright test --project=chromium",
    "test:firefox": "npx playwright test --project=firefox",
    "test:webkit": "npx playwright test --project=webkit",
    "test:allure": "npx playwright test; npm run allure:generate && npm run allure:open",
    "report": "npx playwright show-report",
    "allure:generate": "allure generate allure-results --clean -o allure-report",
    "allure:open": "allure open allure-report",
    "allure:serve": "allure serve allure-results",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@playwright/test": "^1.44.0",
    "@types/node": "^20.19.41",
    "allure-commandline": "^2.29.0",
    "allure-playwright": "^3.3.0",
    "typescript": "^5.4.0"
  }
}
